# Django
SECRET_KEY=changeme-generate-a-strong-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données
# postgresql (défaut) ou sqlite3 pour un démarrage local sans PostgreSQL
DB_ENGINE=postgresql
DB_NAME=bbk_digital
